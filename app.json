{
  "expo": {
    "name": "ZipSender",
    "slug": "zipsender",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "zipsender",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101010"
    },
    "android": {
      "package": "com.zipsender.app",
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101010"
      },
      "permissions": [
        "android.permission.INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "mimeType": "video/*" }],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.zipsender.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ZipSender needs access to save downloaded files.",
        "NSDocumentsFolderUsageDescription": "ZipSender needs access to save downloaded files."
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-system-ui",
      [
        "expo-file-system",
        {}
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
