# Copy this to .env and fill in your Convex deployment URL.
# In GitHub Actions, add EXPO_PUBLIC_CONVEX_URL as a repository secret.
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Google Drive API key (no OAuth needed — just enable Drive API in Google Cloud Console,
# create a restricted API key, and add it here AND in Convex dashboard env vars as GOOGLE_API_KEY)
EXPO_PUBLIC_GOOGLE_API_KEY=your-google-api-key-here
